<%- include('partials/header', { title: 'Blogs - BAKHT' }) %>

<section class="section">
  <div class="container">
    <h1 class="page-title">All Blog Posts</h1>
    <% if (blogs.length > 0) { %>
    <div class="card-grid">
      <% blogs.forEach(blog => { %>
      <a href="/blogs/<%= blog.id %>" class="card card-blog">
        <h3><%= blog.title %></h3>
        <span class="card-date"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p class="empty-state">No blog posts yet. Posts will appear here once generated from viable jobs.</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
