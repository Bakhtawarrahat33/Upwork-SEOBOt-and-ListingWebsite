<%- include('partials/header', { title: `${product.title} - BAKHT` }) %>

<section class="section">
  <div class="container detail-page">
    <a href="/products" class="back-link">&larr; Back to Products</a>
    <h1 class="detail-title"><%= product.title %></h1>
    
    <% if (data.TAGLINE) { %>
    <p class="detail-tagline"><%= data.TAGLINE %></p>
    <% } %>

    <% if (data.OVERVIEW) { %>
    <div class="detail-section">
      <h2>Overview</h2>
      <p><%= data.OVERVIEW %></p>
    </div>
    <% } %>

    <% if (data.FEATURES) { %>
    <div class="detail-section">
      <h2>Features</h2>
      <ul>
        <% data.FEATURES.split('\n').filter(l => l.trim()).forEach(f => { %>
        <li><%= f.replace(/^-\s*/, '') %></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <% if (data.WHO_IT_IS_FOR) { %>
    <div class="detail-section">
      <h2>Who It's For</h2>
      <p><%= data.WHO_IT_IS_FOR %></p>
    </div>
    <% } %>

    <% if (data.TECH_STACK) { %>
    <div class="detail-section">
      <h2>Tech Stack</h2>
      <p><%= data.TECH_STACK %></p>
    </div>
    <% } %>

    <% if (data.PRICE_NOTE) { %>
    <div class="detail-section">
      <p class="price-note"><%= data.PRICE_NOTE %></p>
    </div>
    <% } %>

    <% if (data.CALL_TO_ACTION) { %>
    <div class="detail-section cta-section">
      <p class="cta-text"><%= data.CALL_TO_ACTION %></p>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
