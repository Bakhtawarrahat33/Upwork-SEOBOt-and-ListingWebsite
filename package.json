{
  "name": "ai-automation-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + React + Tailwind dashboard for automation modules (GitHub Repo generator)",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev:vite": "vite --config vite.renderer.config.ts",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 NODE_ENV=development electron .",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "node --enable-source-maps ./src/main/main.js",
    "build": "vite build --config vite.renderer.config.ts && vite build --config vite.preload.config.ts && node ./scripts/build-main.mjs",
    "build:main": "node ./scripts/build-main.mjs",
    "build:dist": "npm run build && cross-env NODE_ENV=production electron-builder --config electron-builder.yml",
    "package": "cross-env NODE_ENV=production electron-builder --config electron-builder.yml",
    "lint": "eslint .",
    "start": "electron ."
  },
  "build": {
    "appId": "com.example.aiautomationdashboard",
    "productName": "AI Automation Dashboard",
    "files": [
      "dist/**",
      "main.js",
      "package.json",
      "upwork-discord-bot/**",
      "prompts/**"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.67.0",
    "@electron/remote": "^2.1.2",
    "axios": "1.12.2",
    "core-util-is": "1.0.3",
    "dotenv": "17.2.3",
    "electron-log": "^5.1.2",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.2.10",
    "jsdom": "27.0.0",
    "jsonrepair": "3.13.1",
    "lucide-react": "^0.471.0",
    "nanoid": "5.1.6",
    "pg": "8.21.0",
    "puppeteer": "23.11.1",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-html": "16.0.1",
    "turndown": "7.2.1",
    "turndown-plugin-gfm": "1.0.2",
    "uuid": "13.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
