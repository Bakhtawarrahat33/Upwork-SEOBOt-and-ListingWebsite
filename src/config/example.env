# Example environment variables for AI Automation Dashboard
# Copy to .env and fill values

# Google Service Account JSON path (optional if using OAuth via UI)
GOOGLE_APPLICATION_CREDENTIALS=

# ChatGPT session cookie (alternative to per-campaign input)
CHATGPT_SESSION_TOKEN=

# ChatGPT login credentials (used for automated login when session cookie expires)
# CHATGPT_EMAIL_BAKHTAWAR=your_email@example.com
# CHATGPT_PASSWORD_BAKHTAWAR=your_password
# CHATGPT_EMAIL_FATIMA=your_email@example.com
# CHATGPT_PASSWORD_FATIMA=your_password
